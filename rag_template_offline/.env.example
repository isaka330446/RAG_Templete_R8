# URL and port settings belong in config/settings.json.
# Keep .env limited to the settings file path and non-URL overrides.
SETTINGS_PATH=config/settings.json
APP_ENV=offline

# OpenAI-compatible local LLM API metadata
LLM_API_KEY=dummy
LLM_MODEL=local-model

# Smaller local LLM for approved-QA alias generation and gray-zone intent judge
ALIAS_LLM_API_KEY=dummy
ALIAS_LLM_MODEL=small-local-model
ALIAS_LLM_TEMPERATURE=0.0
ALIAS_LLM_MAX_TOKENS=800
ALIAS_LLM_TIMEOUT_SEC=60

# OpenAI-compatible local embedding API metadata
EMBEDDING_API_KEY=dummy
EMBEDDING_MODEL=BAAI/bge-m3

# Optional reranker
RERANKER_ENABLED=false

# Chat log SQLite
RAG_LOG_ENABLED=true
RAG_LOG_REQUIRED=true
RAG_LOG_SQLITE_PATH=logs/rag_chat_logs.sqlite
RAG_LOG_BUSY_TIMEOUT_MS=10000
RAG_LOG_CONNECT_TIMEOUT_SEC=30
RAG_LOG_STARTUP_WRITE_CHECK=true
RAG_LOG_MAX_SOURCE_PREVIEW_CHARS=500
RAG_LOG_STORE_FULL_SOURCE_TEXT=false

# Approved QA cache SQLite
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_REQUIRED=true
ANSWER_CACHE_SQLITE_PATH=logs/answer_cache.sqlite
ANSWER_CACHE_HIGH_SIMILARITY_THRESHOLD=0.88
ANSWER_CACHE_SEMANTIC_ACCEPT_THRESHOLD=0.88
ANSWER_CACHE_SEMANTIC_GRAY_THRESHOLD=0.82
ANSWER_CACHE_MARGIN_THRESHOLD=0.03
ANSWER_CACHE_INTENT_JUDGE_GRAY_MIN=0.82
ANSWER_CACHE_ENABLE_LLM_INTENT_JUDGE=false
ANSWER_CACHE_ENABLE_ALIAS_GENERATION=true
ANSWER_CACHE_MAX_ALIASES_PER_QA=8
ANSWER_CACHE_GENERATED_ALIAS_DEFAULT_STATUS=active
ANSWER_CACHE_CORPUS_VERSION=rag_template_v1
ANSWER_CACHE_INDEX_VERSION=bge-m3_chroma_v1

# SearchTag is retained as an optional retrieval helper.
SEARCH_TAGS_ENABLED=true
SEARCH_TAGS_ADMIN_EDIT_ENABLED=false
SEARCH_TAGS_SHOW_IMPROVEMENT_CANDIDATES=false
