# vLLM or other OpenAI-compatible local LLM API
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=dummy
LLM_MODEL=local-model

# OpenAI-compatible local embedding API
EMBEDDING_BASE_URL=http://127.0.0.1:8002/v1
EMBEDDING_API_KEY=dummy
EMBEDDING_MODEL=BAAI/bge-m3

# Optional reranker API
RERANKER_BASE_URL=http://127.0.0.1:8003
RERANKER_ENABLED=false

# Vector DB
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_CHROMA_PATH=indexes/chroma
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_children
QDRANT_LOCAL_PATH=
QDRANT_PREFER_GRPC=false

# Allowed Streamlit origins
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Chat log SQLite
RAG_LOG_ENABLED=true
RAG_LOG_SQLITE_PATH=logs/rag_chat_logs.sqlite

# Approved QA cache
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_SQLITE_PATH=logs/answer_cache.sqlite
ANSWER_CACHE_HIGH_SIMILARITY_THRESHOLD=0.88
ANSWER_CACHE_CORPUS_VERSION=default
ANSWER_CACHE_INDEX_VERSION=default

# Active/staging index release manifest
RELEASE_MANIFEST_PATH=indexes/release_manifest.json
RELEASE_DEFAULT_CORPUS_VERSION=default
RELEASE_DEFAULT_INDEX_VERSION=default
